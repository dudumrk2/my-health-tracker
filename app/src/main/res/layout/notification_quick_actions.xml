<?xml version="1.0" encoding="utf-8"?>
<!--
  Custom content for the ongoing Quick Actions notification. Used with
  NotificationCompat.DecoratedCustomViewStyle so the system still draws the app
  icon/name/time and handles light/dark theming. Text uses the androidx
  TextAppearance.Compat.Notification styles so colors adapt to the notification
  background (a manual ?android:textColor* renders with wrong contrast here).

  Each action cell is a clickable two-line column (emoji over label); the water
  cell intentionally shows only an enlarged drop (no label).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/notification_water_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="6dp"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Title" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3">

        <!-- Add workout -->
        <LinearLayout
            android:id="@+id/action_workout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="💪"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="אימון"
                android:textAppearance="@style/TextAppearance.Compat.Notification" />
        </LinearLayout>

        <!-- Add meal -->
        <LinearLayout
            android:id="@+id/action_meal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="🥗"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="ארוחה"
                android:textAppearance="@style/TextAppearance.Compat.Notification" />
        </LinearLayout>

        <!-- Add water (drop only, no label) -->
        <LinearLayout
            android:id="@+id/action_water"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="💧"
                android:textSize="28sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
